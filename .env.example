# MongoDB connection. Local dev default assumes a mongod running on the default port.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=makhlouf

# Private key used to encrypt/sign the session cookie. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=replace-with-a-random-32-plus-character-secret
